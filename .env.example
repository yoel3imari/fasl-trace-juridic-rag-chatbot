# ==========================================
# Supabase Configuration
# ==========================================
# Get these from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# backend-only — never prefix with NEXT_PUBLIC_
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==========================================
# Database
# ==========================================
# backend-only — never prefix with NEXT_PUBLIC_
# Connection string for PostgreSQL (manual local mode)
# NOTE: docker-compose.yml overrides this for Docker mode
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/legal_rag
TEST_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5433/test_legal_rag

# Production PostgreSQL credentials (for docker-compose.prod.yml)
POSTGRES_DB=legal_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Production MinIO credentials (for docker-compose.prod.yml)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ==========================================
# Vector DB & LLM
# ==========================================
# backend-only — never prefix with NEXT_PUBLIC_
# For local dev (docker-compose.yml): use 'localhost' (ports exposed)
# For production (docker-compose.prod.yml): use 'milvus' (internal Docker network)
MILVUS_HOST=localhost
MILVUS_PORT=19530
OPENAI_API_KEY=your-openai-api-key

# ==========================================
# Encryption
# ==========================================
# Generate with: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=your-base64-encoded-32-byte-key

# ==========================================
# Frontend (Next.js public vars)
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000

# ==========================================
# OpenAPI
# ==========================================
OPENAPI_URL=/openapi.json
OPENAPI_OUTPUT_FILE=../frontend/openapi.json
