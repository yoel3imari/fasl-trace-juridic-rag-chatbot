# ==========================================
# Supabase Configuration
# ==========================================
# Get these from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# ⚠️ backend-only — never prefix with NEXT_PUBLIC_
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==========================================
# Database
# ==========================================
# ⚠️ backend-only — never prefix with NEXT_PUBLIC_
# Connection string for PostgreSQL (manual local mode)
# NOTE: docker-compose.yml overrides this for Docker mode
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/precise_rag

# ==========================================
# Vector DB & LLM
# ==========================================
# ⚠️ backend-only — never prefix with NEXT_PUBLIC_
MILVUS_HOST=localhost
MILVUS_PORT=19530
OPENAI_API_KEY=your-openai-api-key

# ==========================================
# Frontend (Next.js public vars)
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000
